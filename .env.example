# --- LLM (any OpenAI-compatible chat-completions endpoint) ----------------
# Defaults below target the Vercel AI Gateway — the recommended path because
# it's a single key for both chat and embeddings and routes to current Google,
# OpenAI and Anthropic models. Sign up: https://vercel.com/ai-gateway
#
# To stay all-local instead, swap the three values below for e.g.:
#   OPENAI_API_KEY=sk-lm-anything
#   OPENAI_BASE_URL=http://127.0.0.1:1234/v1
#   OPENAI_MODEL=qwen3.6-27b
# Anything OpenAI-compatible works (LM Studio, Ollama, vLLM, llama.cpp,
# Together, Groq, Mistral, ...). See docs/ADR_model_choices.md for benchmarks.
OPENAI_API_KEY=vck_replace_me
OPENAI_BASE_URL=https://ai-gateway.vercel.sh/v1
OPENAI_MODEL=google/gemini-2.5-flash
# max_tokens per request. Reasoning models (qwen3, deepseek-r1, gemini-flash)
# need generous head-room — they spend tokens on internal thinking before
# emitting the JSON answer. 8192 covers reranks up to ~30 candidates on
# gemini-2.5-flash without truncation. Set to 0 to let the server pick its
# default (e.g. for fixed-budget non-reasoning models).
OPENAI_MAX_TOKENS=8192

# --- Embedding (Stage 1: dense retrieval) ---------------------------------
# Defaults reuse the Vercel AI Gateway (leaving _API_KEY / _BASE_URL blank
# falls back to OPENAI_*). For all-local set:
#   EMBEDDING_BASE_URL=http://127.0.0.1:1234/v1
#   EMBEDDING_MODEL=text-embedding-granite-embedding-278m-multilingual
# Granite-278m-multilingual ships with LM Studio and reaches EN↔DE
# crosslingual cosine 0.81 on the test set. See docs/PIPELINE.md.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Reranker (Stage 2: relevance gate before NLI) -----------------------
# llm:  single batched LLM call rates top-K retrieved candidates for
#       relevance. Keeps top RERANK_KEEP above RERANK_THRESHOLD.
# off:  skip Stage 2 entirely. Use when latency isn't a concern.
RERANK_MODE=llm
RERANK_KEEP=5
RERANK_THRESHOLD=0.5

# --- NLI (Stage 3: polarity gate) -----------------------------------------
# llm-judge: reuse OPENAI_* model as a 3-class entailment judge (no extra
#            model to load). Slower but immediate.
# dedicated: not yet implemented; reserved for a separate NLI server.
NLI_MODE=llm-judge

# --- Labeler identity -----------------------------------------------------
# DID is a placeholder until you register a Bluesky service account.
# Signing key is generated on first run if blank.
LABELER_DID=did:plc:placeholder-replace-after-setup
# Optional handle (no leading "@") — used to detect plain-text mentions when
# the post has no structured facet. Leave blank if your DID alone is enough.
LABELER_HANDLE=
LABELER_SIGNING_KEY=
LABELER_PORT=14831
LABELER_HOSTNAME=http://localhost:14831

# --- Ingest ---------------------------------------------------------------
# Jetstream relay (US-east is fine from EU; see https://docs.bsky.app/blog/jetstream)
JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe
# Optional: replay posts from a fixture file instead of live Jetstream
# JETSTREAM_FIXTURE=fixtures/posts.jsonl

# --- Triggers — what causes the LLM to run on a post ----------------------
# Default: mentions + reports. Firehose is opt-in (volume kills a single LLM).
# Watchlist is empty by default; add DIDs to always check those accounts.
TRIGGER_FIREHOSE=false
TRIGGER_MENTIONS=true
TRIGGER_REPORTS=true
TRIGGER_WATCHLIST=
# Bluesky AppView, used to fetch the parent post when a mention is in a reply
# or when a report subject URI arrives without text. `public.api.bsky.app` is
# the unauthenticated read-only AppView; no session required.
APPVIEW_URL=https://public.api.bsky.app

# Require a valid atproto service JWT on the createReport endpoint.
# Default on — a real Bluesky client signs the request via its PDS.
# Flip to false only for local curl-based testing.
REQUIRE_REPORT_AUTH=true
# PLC directory used to resolve report-issuer DIDs to signing keys.
PLC_DIRECTORY_URL=https://plc.directory
# Authed fallback — used only when REPLY_TO_MENTIONS=true and the public
# AppView returns 429/5xx/network-error. Reuses the labeler's access token.
APPVIEW_AUTHED_URL=https://api.bsky.app

# --- Reply to @mention author --------------------------------------------
# When true, the labeler replies to the mention post after a mention-triggered
# label is accepted. Requires Bluesky service-account creds (app password).
# See docs/TRIGGER_MENTIONS.md § Reply-to-mention.
REPLY_TO_MENTIONS=false
LABELER_BSKY_SERVICE=https://bsky.social
LABELER_BSKY_IDENTIFIER=
LABELER_BSKY_APP_PASSWORD=
# Public base URL of the labeler's detail page (embedded in replies as a link).
# Example: https://facts.example.org
LABELER_DETAIL_BASE_URL=
# Fallback language for replies when the mention post has no `langs` field
# or uses an unsupported language. Currently supported: en, de.
LABELER_REPLY_DEFAULT_LANG=en

# --- HITL -----------------------------------------------------------------
# "stdin" (default) prints proposals in the terminal.
# "telegram"     — every proposal goes to a Telegram chat with accept/reject
#                  buttons. Needs TG_BOT_TOKEN + TG_REVIEWER_CHAT_ID.
# "auto"         — decides without human input via the AUTO_MIN_* policy below.
# "auto-telegram"— hybrid: auto-accept above the bar, forward the rest to
#                  Telegram for a manual decision. Needs the TG_* values too.
HITL_MODE=stdin
TG_BOT_TOKEN=
TG_REVIEWER_CHAT_ID=
# Auto policy (used by HITL_MODE=auto and the auto half of auto-telegram).
# Accept when aggregated confidence ≥ MIN_CONFIDENCE AND votes ≥ MIN_VOTES,
# otherwise defer (or push to Telegram in auto-telegram mode).
HITL_AUTO_MIN_CONFIDENCE=0.6
HITL_AUTO_MIN_VOTES=2

# --- Storage --------------------------------------------------------------
SQLITE_PATH=data/labeler.sqlite

# --- ClaimReview ingest source --------------------------------------------
CLAIMREVIEW_FEED_PATH=data.json
# Path to the publisher allowlist. The Google Data Commons feed is open-
# submission and ships SEO spam alongside real fact-checkers; only entries
# whose author.url host matches a line in this file are ingested. See
# docs/FEED_QUALITY.md for the curation policy.
CLAIMREVIEW_PUBLISHER_ALLOWLIST=config/claimreview-publishers-allowlist.txt

# --- Logging --------------------------------------------------------------
# pino level: trace · debug · info · warn · error · fatal
LOG_LEVEL=info
